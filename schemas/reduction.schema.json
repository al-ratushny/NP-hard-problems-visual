{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nphard-vis.local/schemas/reduction.schema.json",
  "title": "Reduction Dataset",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "reductions"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "reductions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "from", "to", "type", "idea", "references"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
          },
          "from": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
          },
          "to": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
          },
          "type": {
            "type": "string",
            "enum": ["karp"]
          },
          "idea": {
            "type": "string",
            "minLength": 1
          },
          "references": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label", "url"],
              "properties": {
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                }
              }
            }
          }
        }
      }
    }
  }
}
